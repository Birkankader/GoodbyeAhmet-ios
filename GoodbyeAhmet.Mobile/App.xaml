<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GoodbyeAhmet.Mobile"
             xmlns:conv="clr-namespace:GoodbyeAhmet.Mobile.Converters"
             x:Class="GoodbyeAhmet.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters used in MainPage.xaml -->
            <conv:IsNotNullConverter      x:Key="IsNotNullConverter"/>
            <conv:ConnectedColorConverter  x:Key="ConnectedColorConverter"/>
            <conv:InvertBoolConverter      x:Key="InvertBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
