<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GoodbyeAhmet.Mobile.ViewModels"
             xmlns:models="clr-namespace:GoodbyeAhmet.Mobile.Models"
             xmlns:svc="clr-namespace:GoodbyeAhmet.Mobile.Services"
             x:Class="GoodbyeAhmet.Mobile.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid RowDefinitions="Auto,*,Auto"
              Padding="24,48,24,24"
              RowSpacing="0">

            <!-- ══════════ Row 0 — Header ══════════ -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="Auto,*"
                  Margin="0,0,0,20">
                <!-- Back button -->
                <Border StrokeShape="RoundRectangle 6"
                        Stroke="Transparent"
                        BackgroundColor="Transparent"
                        Padding="4"
                        WidthRequest="36"
                        HeightRequest="36"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                    <Path Data="M20,11 L7.83,11 L13.42,5.41 L12,4 L4,12 L12,20 L13.41,18.59 L7.83,13 L20,13 Z"
                          Fill="#1E90FF"
                          Aspect="Uniform"
                          WidthRequest="22"
                          HeightRequest="22"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     Margin="12,0,0,0"
                                     VerticalOptions="Center">
                    <Label Text="{Binding [SettingsTitle], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1E90FF"/>
                    <Label Text="{Binding [AdjustParameters], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="12"
                           TextColor="#B0B0B0"/>
                </VerticalStackLayout>
            </Grid>

            <!-- ══════════ Row 1 — Form ══════════ -->
            <VerticalStackLayout Grid.Row="1"
                                 Spacing="0">

                <!-- ──── Language ──── -->
                <Label Text="{Binding [Language], Source={x:Static svc:LocalizationService.Instance}, StringFormat='{0}'}"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#808080"
                       Margin="0,0,0,8"/>
                <Border StrokeShape="RoundRectangle 8"
                        Stroke="#333333"
                        BackgroundColor="#1E1E1E"
                        Padding="8,4"
                        Margin="0,0,0,20">
                    <Picker ItemsSource="{Binding Languages}"
                            SelectedItem="{Binding SelectedLanguage}"
                            TextColor="White"
                            TitleColor="#606060"
                            Title="Select language…"
                            HorizontalOptions="Fill"/>
                </Border>

                <!-- ──── Preset ──── -->
                <Label Text="{Binding [Preset], Source={x:Static svc:LocalizationService.Instance}, StringFormat='{0}'}"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#808080"
                       Margin="0,0,0,8"/>
                <Border StrokeShape="RoundRectangle 8"
                        Stroke="#333333"
                        BackgroundColor="#1E1E1E"
                        Padding="8,4"
                        Margin="0,0,0,24">
                    <Picker ItemsSource="{Binding Presets}"
                            SelectedItem="{Binding SelectedPreset}"
                            ItemDisplayBinding="{Binding Path=DisplayName, x:DataType='models:BypassPreset'}"
                            TextColor="White"
                            TitleColor="#606060"
                            Title="Select preset…"
                            HorizontalOptions="Fill"/>
                </Border>

                <!-- ──── Advanced Parameters ──── -->
                <Label Text="{Binding [AdvancedParameters], Source={x:Static svc:LocalizationService.Instance}}"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#808080"
                       Margin="0,0,0,16"/>

                <!-- Two-column grid like WPF -->
                <Grid ColumnDefinitions="*,16,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="0"
                      ColumnSpacing="0">

                    <!-- Left Col: TTL -->
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding [TTL], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="12"
                           TextColor="#B0B0B0"
                           Margin="0,0,0,6"/>
                    <Border Grid.Row="1"
                            Grid.Column="0"
                            StrokeShape="RoundRectangle 6"
                            Stroke="#333333"
                            BackgroundColor="#252525"
                            Padding="10,0"
                            HeightRequest="42"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding Ttl}"
                               Keyboard="Numeric"
                               TextColor="White"
                               PlaceholderColor="#606060"
                               Placeholder="0"
                               VerticalOptions="Center"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Right Col: Split Position -->
                    <Label Grid.Row="0"
                           Grid.Column="2"
                           Text="{Binding [SplitPosition], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="12"
                           TextColor="#B0B0B0"
                           Margin="0,0,0,6"/>
                    <Border Grid.Row="1"
                            Grid.Column="2"
                            StrokeShape="RoundRectangle 6"
                            Stroke="#333333"
                            BackgroundColor="#252525"
                            Padding="10,0"
                            HeightRequest="42"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding SplitPosition}"
                               Keyboard="Numeric"
                               TextColor="White"
                               PlaceholderColor="#606060"
                               Placeholder="2"
                               VerticalOptions="Center"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Left Col: DNS v4 Address -->
                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Text="{Binding [DNSV4Address], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="12"
                           TextColor="#B0B0B0"
                           Margin="0,0,0,6"/>
                    <Border Grid.Row="3"
                            Grid.Column="0"
                            StrokeShape="RoundRectangle 6"
                            Stroke="#333333"
                            BackgroundColor="#252525"
                            Padding="10,0"
                            HeightRequest="42"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding DnsV4Address}"
                               Keyboard="Default"
                               TextColor="White"
                               PlaceholderColor="#606060"
                               Placeholder="e.g. 77.88.8.8"
                               VerticalOptions="Center"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Right Col: DNS v4 Port -->
                    <Label Grid.Row="2"
                           Grid.Column="2"
                           Text="{Binding [DNSV4Port], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="12"
                           TextColor="#B0B0B0"
                           Margin="0,0,0,6"/>
                    <Border Grid.Row="3"
                            Grid.Column="2"
                            StrokeShape="RoundRectangle 6"
                            Stroke="#333333"
                            BackgroundColor="#252525"
                            Padding="10,0"
                            HeightRequest="42"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding DnsV4Port}"
                               Keyboard="Numeric"
                               TextColor="White"
                               PlaceholderColor="#606060"
                               Placeholder="53"
                               VerticalOptions="Center"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Left Col: DNS v6 Address -->
                    <Label Grid.Row="4"
                           Grid.Column="0"
                           Text="{Binding [DNSV6Address], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="12"
                           TextColor="#B0B0B0"
                           Margin="0,0,0,6"/>
                    <Border Grid.Row="5"
                            Grid.Column="0"
                            StrokeShape="RoundRectangle 6"
                            Stroke="#333333"
                            BackgroundColor="#252525"
                            Padding="10,0"
                            HeightRequest="42"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding DnsV6Address}"
                               Keyboard="Default"
                               TextColor="White"
                               PlaceholderColor="#606060"
                               Placeholder="e.g. 2a02:6b8::feed:0ff"
                               VerticalOptions="Center"
                               BackgroundColor="Transparent"/>
                    </Border>

                    <!-- Right Col: DNS v6 Port -->
                    <Label Grid.Row="4"
                           Grid.Column="2"
                           Text="{Binding [DNSV6Port], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="12"
                           TextColor="#B0B0B0"
                           Margin="0,0,0,6"/>
                    <Border Grid.Row="5"
                            Grid.Column="2"
                            StrokeShape="RoundRectangle 6"
                            Stroke="#333333"
                            BackgroundColor="#252525"
                            Padding="10,0"
                            HeightRequest="42"
                            Margin="0,0,0,16">
                        <Entry Text="{Binding DnsV6Port}"
                               Keyboard="Numeric"
                               TextColor="White"
                               PlaceholderColor="#606060"
                               Placeholder="53"
                               VerticalOptions="Center"
                               BackgroundColor="Transparent"/>
                    </Border>
                </Grid>

                <!-- ──── Ad-Block (DNS Sinkhole) ──── -->
                <Label Text="{Binding [AdBlockTitle], Source={x:Static svc:LocalizationService.Instance}}"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#808080"
                       Margin="0,8,0,12"/>

                <!-- Enable Ad-Block toggle -->
                <Grid ColumnDefinitions="*,Auto"
                      Margin="0,0,0,12">
                    <Label Text="{Binding [EnableAdBlocker], Source={x:Static svc:LocalizationService.Instance}}"
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="White"/>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding AdBlockEnabled}"
                            OnColor="#1E90FF"
                            ThumbColor="White"/>
                </Grid>

                <!-- Blocklist URL -->
                <Label Text="{Binding [BlocklistUrl], Source={x:Static svc:LocalizationService.Instance}}"
                       FontSize="12"
                       TextColor="#B0B0B0"
                       Margin="0,0,0,6"/>
                <Border StrokeShape="RoundRectangle 6"
                        Stroke="#333333"
                        BackgroundColor="#252525"
                        Padding="10,0"
                        HeightRequest="42"
                        Margin="0,0,0,12">
                    <Entry Text="{Binding AdBlockListUrl}"
                           Keyboard="Url"
                           TextColor="White"
                           PlaceholderColor="#606060"
                           Placeholder="https://..."
                           FontSize="12"
                           VerticalOptions="Center"
                           BackgroundColor="Transparent"/>
                </Border>

                <!-- Load / Status row -->
                <Grid ColumnDefinitions="Auto,*"
                      Margin="0,0,0,16">
                    <Button Grid.Column="0"
                            Text="{Binding [LoadList], Source={x:Static svc:LocalizationService.Instance}}"
                            Command="{Binding LoadBlocklistCommand}"
                            BackgroundColor="#2D2D2D"
                            TextColor="#1E90FF"
                            FontSize="13"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="38"
                            Padding="16,0"
                            IsEnabled="{Binding IsLoadingBlocklist, Converter={StaticResource InvertBoolConverter}}"/>
                    <Label Grid.Column="1"
                           Text="{Binding AdBlockStatus}"
                           FontSize="12"
                           TextColor="#B0B0B0"
                           VerticalOptions="Center"
                           Margin="12,0,0,0"/>
                </Grid>

                <!-- ──── Toggle Switches ──── -->
                <Label Text="{Binding [Options], Source={x:Static svc:LocalizationService.Instance}}"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#808080"
                       Margin="0,8,0,12"/>

                <!-- Split ClientHello -->
                <Grid ColumnDefinitions="*,Auto"
                      Margin="0,0,0,12">
                    <Label Text="{Binding [SplitClientHello], Source={x:Static svc:LocalizationService.Instance}}"
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="White"/>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding SplitClientHello}"
                            OnColor="#1E90FF"
                            ThumbColor="White"/>
                </Grid>

                <!-- Mix Host Case -->
                <Grid ColumnDefinitions="*,Auto"
                      Margin="0,0,0,12">
                    <Label Text="{Binding [MixHostCase], Source={x:Static svc:LocalizationService.Instance}}"
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="White"/>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding MixHostCase}"
                            OnColor="#1E90FF"
                            ThumbColor="White"/>
                </Grid>

                <!-- Start on Boot -->
                <Grid ColumnDefinitions="*,Auto"
                      Margin="0,0,0,12">
                    <Label Text="{Binding [LaunchOnStart], Source={x:Static svc:LocalizationService.Instance}}"
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="White"/>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding StartOnBoot}"
                            OnColor="#1E90FF"
                            ThumbColor="White"/>
                </Grid>

                <!-- Activate on Start -->
                <Grid ColumnDefinitions="*,Auto"
                      Margin="0,0,0,12">
                    <Label Text="{Binding [ActivateOnStart], Source={x:Static svc:LocalizationService.Instance}}"
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="White"/>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding ActivateOnStart}"
                            OnColor="#1E90FF"
                            ThumbColor="White"/>
                </Grid>
            </VerticalStackLayout>

            <!-- ══════════ Row 2 — Buttons ══════════ -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,16,*"
                  Margin="0,20,0,0">

                <!-- Reset -->
                <Button Grid.Column="0"
                        Text="{Binding [Reset], Source={x:Static svc:LocalizationService.Instance}}"
                        Command="{Binding ResetCommand}"
                        BackgroundColor="#2D2D2D"
                        TextColor="#B0B0B0"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="50"/>

                <!-- Save -->
                <Button Grid.Column="2"
                        Text="{Binding [SaveChanges], Source={x:Static svc:LocalizationService.Instance}}"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="#1E90FF"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="50"/>
            </Grid>

        </Grid>
    </ScrollView>

</ContentPage>
